    website: "https://clawtouch.cn"
repository-code: "https://github.com/tinqiao-oss/clawtouch-mcp"
url: "https://github.com/tinqiao-oss/clawtouch-mcp"
license: MIT
keywords:
  - MCP
  - HID
  - agent
  - tool-use
  - automation
